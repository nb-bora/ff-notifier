# =============================================================================
# Development Dockerfile — hot reload & dev tools
# =============================================================================
FROM python:3.11

WORKDIR /app

# System dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        gcc \
        git \
        curl \
        libpango-1.0-0 \
        libpangoft2-1.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies (editable + dev extras)
COPY pyproject.toml ./
COPY src/           ./src/
RUN pip install --no-cache-dir -e ".[dev]"

# Application source
COPY . .

# Environment
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    ENVIRONMENT=dev

EXPOSE 8001

CMD ["uvicorn", "main:app", \
     "--app-dir", "src", \
     "--host", "0.0.0.0", \
     "--port", "8001", \
     "--reload"]