# =============================================================================
# Environment Configuration Template
# Copy to .env and fill in actual values
# =============================================================================


# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=af-south-1
AWS_PROFILE=


# -----------------------------------------------------------------------------
# S3 Configuration
# -----------------------------------------------------------------------------
S3_PDF_ENABLED=true
S3_PDF_BUCKET=
S3_PDF_PREFIX=pdf_reports/
S3_PDF_SSE_KMS_KEY_ID=


# -----------------------------------------------------------------------------
# SQS Configuration
# -----------------------------------------------------------------------------
SQS_FARE_RESULT_QUEUE_URL=
SQS_MAX_MESSAGES=10
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT=300


# -----------------------------------------------------------------------------
# SES Configuration
# -----------------------------------------------------------------------------
SES_SENDER_EMAIL=
SES_MAX_RETRIES=3
SES_SANDBOX_MODE=true
SES_SANDBOX_TEST_EMAIL=


# -----------------------------------------------------------------------------
# PDF & QR Code
# -----------------------------------------------------------------------------
PDF_ENABLED=true
PDF_RENDER_TIMEOUT_SECONDS=120
QR_CODE_ENABLED=true
# VERBOSE_WEASYPRINT=true


# -----------------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------------
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Report Configuration
# -----------------------------------------------------------------------------
REPORT_SAVE_TO_DISK=false
REPORT_OPEN_AFTER_GENERATE=false


# -----------------------------------------------------------------------------
# Parameter Store
# -----------------------------------------------------------------------------
PARAMETER_STORE_ENABLED=true
EMAIL_TEMPLATE_PARAMETER=/fairfare/email-template
PDF_SETTINGS_PARAMETER=/fairfare/pdf-settings


# -----------------------------------------------------------------------------
# Consumer Configuration
# -----------------------------------------------------------------------------
CONSUMER_ENABLED=true
CONSUMER_MAX_RETRIES=3
CONSUMER_ERROR_DELAY_SECONDS=5
CONSUMER_MAX_CONCURRENT_MESSAGES=10


# -----------------------------------------------------------------------------
# AWS Observability (X-Ray)
# -----------------------------------------------------------------------------
ENABLE_XRAY=false
# AWS_XRAY_DAEMON_ADDRESS=localhost:2000